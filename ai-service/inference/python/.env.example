# Base retrieval config
VISION_BACKEND=auto
VISION_TOP_K_DEFAULT=4
VISION_IMAGE_SIZE=224
VISION_RETRIEVAL_POOL_SIZE=12

# ONNX / hybrid fallback assets
VISION_MODEL_BUNDLE=
VISION_MODEL_PATH=../../model/food_classifier.onnx
VISION_LABELS_PATH=../../model/labels.json
VISION_MODEL_VERSION=food-cls-v1
VISION_MANIFEST_PATH=../../model/category_manifest.json
VISION_RETRIEVAL_BANK_PATH=../../model/retrieval_bank.json
VISION_CLIP_TEXT_BANK_PATH=../../model/clip_text_bank.npz
VISION_CLIP_TEXT_BANK_META_PATH=../../model/clip_text_bank.meta.json

# LLaVA-NeXT backend
VISION_LLAVA_MODEL_ID=llava-hf/llava-v1.6-mistral-7b-hf
VISION_LLAVA_MODEL_REVISION=main
VISION_LLAVA_MODEL_VERSION=llava-next-v1.6-mistral-7b
VISION_LLAVA_DEVICE=
VISION_LLAVA_TORCH_DTYPE=auto
VISION_LLAVA_MAX_NEW_TOKENS=256
VISION_LLAVA_TEMPERATURE=0.0
VISION_LLAVA_TOP_P=1.0
VISION_LLAVA_DO_SAMPLE=false
VISION_LLAVA_CATALOG_LIMIT=32
VISION_LLAVA_ALIAS_LIMIT=3
