# Copy this file to .env for local development.
# Optional overrides can go into .env.local when using scripts/start-local-discovery.ps1.

# Shared auth
APP_JWT_SECRET=replace-with-at-least-32-characters-for-local-dev
APP_JWT_EXPIRE=86400000

# MySQL connection used by the services
MYSQL_HOST=localhost
# Default project setup uses Docker MySQL on localhost:3307.
# Change MYSQL_PORT to 3306 if you want the services to use a MySQL installed on your computer.
MYSQL_PORT=3307
# Host port exposed by docker-compose for the project's MySQL container.
MYSQL_DOCKER_PORT=3307
MYSQL_USERNAME=root
MYSQL_PASSWORD=replace-with-your-local-mysql-password
# Keep this aligned with MYSQL_PASSWORD when you use docker-compose.dev.yml for the project MySQL.
MYSQL_ROOT_PASSWORD=replace-with-your-local-mysql-password
MYSQL_DB=nutrimind_user
MYSQL_FOOD_DB=nutrimind_food
MYSQL_MEAL_DB=nutrimind_meal

# Local IDE defaults. The discovery startup script will override these when needed.
SPRING_PROFILES_ACTIVE=
NACOS_DISCOVERY_ENABLED=false
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_AUTH_TOKEN=bmFjb3MtbG9jYWwtZGV2LXRva2VuLXBsZWFzZS1jaGFuZ2U=
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=security

# Advisor RAG
APP_RAG_MILVUS_URI=http://localhost:19530
# Optional. Leave blank to skip Milvus bootstrap and use local retrieval fallback.
APP_RAG_QWEN_API_KEY=

# GraphRAG / Neo4j
APP_GRAPH_NEO4J_ENABLED=false
APP_GRAPH_NEO4J_URI=bolt://localhost:7687
APP_GRAPH_NEO4J_USERNAME=neo4j
APP_GRAPH_NEO4J_PASSWORD=replace-with-your-local-neo4j-password
APP_GRAPH_NEO4J_DATABASE=neo4j
APP_GRAPH_NEO4J_SYNC_ON_STARTUP=true

# AI service
APP_VISION_ENGINE=qwen
APP_VISION_PYTHON_BASE_URL=http://localhost:8091
APP_VISION_QWEN_ENABLED=true
APP_VISION_QWEN_API_KEY=
APP_VISION_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
APP_VISION_QWEN_MODEL=qwen3-vl-plus
APP_VISION_QWEN_TEMPERATURE=0.1
APP_VISION_QWEN_MAX_TOKENS=1200
# For local model inference, set APP_VISION_ENGINE=python
# and start ai-service/inference/python/start-ai4food-subcategory.ps1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Email verification (example uses QQ Mail SMTP)
APP_EMAIL_VERIFICATION_ENABLED=false
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_PROTOCOL=smtps
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SSL_ENABLE=true
MAIL_STARTTLS_ENABLE=false
APP_EMAIL_VERIFICATION_SUBJECT=NutriMind verification code
APP_EMAIL_VERIFICATION_EXPIRE_SECONDS=300
APP_EMAIL_VERIFICATION_COOLDOWN_SECONDS=60
